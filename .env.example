LOG_OPENSEARCH_ENABLED=false
EMBEDDING_MODEL_ID=

# ─── LLM Provider ───────────────────────────────────────────────────────────
# Set LLM_PROVIDER to one of: ollama | openai | google-genai
# Set LLM_MODEL to the model name for that provider.
# Uncomment the block that matches your chosen provider.

# ── Option 1: Ollama (local) with Gemma ─────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma3:4b
# OLLAMA_BASE_URL=http://localhost:11434

# ── Option 2: OpenAI ────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ── Option 3: Google Gemini ──────────────────────────────────────────────────
LLM_PROVIDER=google-genai
LLM_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=AIzaSyB40etFQJ-c2bRF0xK92OKUvnU8E4XrvoQ

# ─── Optional integrations ──────────────────────────────────────────────────
TAVILY_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LLM_TEMPERATURE=0.7
